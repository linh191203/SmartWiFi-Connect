<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <!-- Exclude the WiFi credentials database from cloud backup and device
         transfer. The AES/GCM key is hardware-bound to the originating device
         via Android Keystore, so the ciphertext is useless on another device. -->
    <cloud-backup>
        <exclude domain="database" path="smart_wifi_connect.db" />
        <exclude domain="database" path="smart_wifi_connect.db-shm" />
        <exclude domain="database" path="smart_wifi_connect.db-wal" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="database" path="smart_wifi_connect.db" />
        <exclude domain="database" path="smart_wifi_connect.db-shm" />
        <exclude domain="database" path="smart_wifi_connect.db-wal" />
    </device-transfer>
</data-extraction-rules>