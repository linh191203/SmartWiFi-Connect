{
  "name": "smartwificonnect-web",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:mobile": "npm run build && npx cap sync",
    "build:android": "npm run build && npx cap sync android",
    "build:ios": "npm run build && npx cap sync ios",
    "android:build": "npm run build:android && cd android && ./gradlew assembleDebug",
    "android:apk": "npm run build:android && cd android && ./gradlew assembleDebug --stacktrace",
    "ios:build": "npm run build:ios && open ios/App/App.xcworkspace"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "@capacitor/ios": "^8.3.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vite-pwa/assets-generator": "^1.0.2",
    "@vitejs/plugin-react": "^4.4.1",
    "@vitest/ui": "^4.1.5",
    "jsdom": "^29.1.0",
    "vite": "^5.4.19",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.5"
  }
}
